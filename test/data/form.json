{
  "title": "Dornori Enterprise Support Center",
  "subtitle": "Smart diagnostics · Self-service resolution",
  "categories": [
    {
      "id": "order_shipping",
      "title": "📦 Order Status & Shipping",
      "questions": [
        {
          "id": "os1",
          "text": "What's your order or shipping concern?",
          "options": [
            {"text": "Where's my order? It's delayed", "summary": "Order delay", "next": "order_tracking", "resolves": false},
            {"text": "Package arrived damaged", "summary": "Damaged package", "next": "damaged_package_check", "resolves": false},
            {"text": "Wrong or missing items", "summary": "Order error", "next": "order_issue_check", "resolves": false},
            {"text": "Need to cancel or return", "summary": "Cancel/return", "next": "cancel_return", "resolves": false},
            {"text": "Tracking number not working", "summary": "Tracking issue", "next": "tracking_not_working", "resolves": false}
          ]
        },
        {
          "id": "order_tracking",
          "text": "How long ago did you place your order?",
          "options": [
            {"text": "Less than 3 days ago", "summary": "Recent order", "next": "recent_order", "resolves": false},
            {"text": "3-7 days ago", "summary": "Processing", "next": "processing_order", "resolves": false},
            {"text": "8-14 days ago", "summary": "Should have arrived", "next": "should_arrived", "resolves": false},
            {"text": "More than 2 weeks ago", "summary": "Seriously delayed", "next": "serious_delay", "resolves": false}
          ]
        },
        {
          "id": "recent_order",
          "text": "Orders take 1-3 business days to process. Check your email (including spam) for tracking.",
          "options": [
            {"text": "Found tracking, thanks!", "summary": "Tracking found", "next": "resolved_end", "resolves": true},
            {"text": "No tracking yet, I'll wait", "summary": "Customer will wait", "next": "resolved_end", "resolves": true},
            {"text": "Still need help finding it", "summary": "Need assistance", "next": "contact", "resolves": false}
          ]
        },
        {
          "id": "processing_order",
          "text": "Most orders ship within 3-5 business days. Did you order during a sale?",
          "options": [
            {"text": "Yes, holiday sale - I'll wait", "summary": "Holiday delay OK", "next": "resolved_end", "resolves": true},
            {"text": "No, normal day - still waiting", "summary": "Should have shipped", "next": "contact", "resolves": false},
            {"text": "I understand, thanks", "summary": "Customer satisfied", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "should_arrived",
          "text": "By 8-14 days, most orders have arrived. Let's troubleshoot:",
          "options": [
            {"text": "Tracking says delivered but no package", "summary": "Missing delivery", "next": "missing_delivery", "resolves": false},
            {"text": "Tracking shows 'in transit' still", "summary": "Carrier delay", "next": "carrier_delay", "resolves": false},
            {"text": "Actually I found it, never mind!", "summary": "Package found", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "missing_delivery",
          "text": "Please: 1) Check with neighbors 2) Check mailroom 3) Wait 24 hours",
          "options": [
            {"text": "Found it! Thanks", "summary": "Package found", "next": "resolved_end", "resolves": true},
            {"text": "Still missing after 24h", "summary": "Really missing", "next": "contact", "resolves": false},
            {"text": "I'll wait and check again", "summary": "Customer will wait", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "carrier_delay",
          "text": "Carriers sometimes have delays. 95% arrive within 3 more days.",
          "options": [
            {"text": "I'll wait, thanks", "summary": "Customer patient", "next": "resolved_end", "resolves": true},
            {"text": "It's been over 5 days", "summary": "Stuck package", "next": "contact", "resolves": false}
          ]
        },
        {
          "id": "serious_delay",
          "text": "2+ weeks is not normal. Please provide your order number for investigation.",
          "options": [
            {"text": "DOR-_____ (I'll provide)", "summary": "Lost package", "next": "contact", "resolves": false},
            {"text": "I'll check again first", "summary": "Customer checks", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "damaged_package_check",
          "text": "Is the PRODUCT damaged or just the box?",
          "options": [
            {"text": "Just the box, product fine", "summary": "Box only", "next": "box_only_damage", "resolves": false},
            {"text": "Product is damaged/broken", "summary": "Product damaged", "next": "product_damaged_photo", "resolves": false},
            {"text": "Actually it's fine, never mind", "summary": "No issue", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "box_only_damage",
          "text": "Great! If product works, no action needed. Does it work?",
          "options": [
            {"text": "Yes, works perfectly", "summary": "All good", "next": "resolved_end", "resolves": true},
            {"text": "No, it's broken too", "summary": "Hidden damage", "next": "product_damaged_photo", "resolves": false}
          ]
