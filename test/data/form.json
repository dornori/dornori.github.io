{
  "title": "Dornori Enterprise Support Center",
  "subtitle": "Smart diagnostics · Self-service resolution · Most issues fixed in under 3 minutes",
  "categories": [
    {
      "id": "order_shipping",
      "title": "📦 Order Status & Shipping",
      "questions": [
        {
          "id": "os1",
          "text": "What's your order or shipping concern?",
          "options": [
            {"text": "Where's my order? It's delayed", "summary": "Order delay", "next": "order_tracking"},
            {"text": "Package arrived damaged", "summary": "Damaged package", "next": "damaged_package_check"},
            {"text": "Wrong or missing items", "summary": "Order error", "next": "order_issue_check"},
            {"text": "Need to cancel or return", "summary": "Cancel/return", "next": "cancel_return"},
            {"text": "Tracking number not working", "summary": "Tracking issue", "next": "tracking_not_working"}
          ]
        },
        {
          "id": "order_tracking",
          "text": "How long ago did you place your order?",
          "options": [
            {"text": "Less than 3 days ago", "summary": "Recent order - still processing", "next": "recent_order"},
            {"text": "3-7 days ago", "summary": "Should have tracking by now", "next": "processing_order"},
            {"text": "8-14 days ago", "summary": "Should have arrived", "next": "should_arrived"},
            {"text": "More than 2 weeks ago", "summary": "Seriously delayed", "next": "serious_delay"}
          ]
        },
        {
          "id": "recent_order",
          "text": "Orders take 1-3 business days to process. Check your email (including spam) for tracking. 95% ship within 3 days.",
          "options": [
            {"text": "Found tracking, thanks!", "summary": "Tracking found", "next": "resolved_end"},
            {"text": "No tracking yet, I'll wait", "summary": "Customer will wait", "next": "resolved_end"},
            {"text": "Still need help finding it", "summary": "Need assistance", "next": "contact"}
          ]
        },
        {
          "id": "processing_order",
          "text": "Most orders ship within 3-5 business days. Did you order during a sale or holiday?",
          "options": [
            {"text": "Yes (Black Friday, Christmas, etc.)", "summary": "Holiday delay - 5-7 days", "next": "holiday_delay"},
            {"text": "No, normal day", "summary": "Should have shipped", "next": "check_payment"},
            {"text": "Not sure", "summary": "Check order", "next": "contact"}
          ]
        },
        {
          "id": "holiday_delay",
          "text": "During sales, processing takes 5-7 business days. Your order should ship soon. Still nothing after 7 days? Contact us.",
          "options": [
            {"text": "I'll wait, thanks", "summary": "Customer patient", "next": "resolved_end"},
            {"text": "It's been over 7 days", "summary": "Still delayed", "next": "contact"}
          ]
        },
        {
          "id": "check_payment",
          "text": "Let's verify payment went through. Check your bank statement. Payment issues cause 90% of delays.",
          "options": [
            {"text": "Payment cleared", "summary": "Payment OK", "next": "contact"},
            {"text": "Payment pending/failed", "summary": "Payment issue", "next": "payment_issue"},
            {"text": "Need to check", "summary": "Customer will check", "next": "resolved_end"}
          ]
        },
        {
          "id": "payment_issue",
          "text": "If payment failed, your order wasn't processed. Please place a new order. Need help?",
          "options": [
            {"text": "I'll place new order", "summary": "Customer will reorder", "next": "resolved_end"},
            {"text": "Help me place it", "summary": "Need assistance", "next": "contact"}
          ]
        },
        {
          "id": "should_arrived",
          "text": "By 8-14 days, most orders have arrived. Let's troubleshoot:",
          "options": [
            {"text": "Tracking says delivered but no package", "summary": "Missing delivery", "next": "missing_delivery"},
            {"text": "Tracking shows 'in transit' still", "summary": "Carrier delay", "next": "carrier_delay"},
            {"text": "No tracking information", "summary": "No tracking", "next": "contact"}
          ]
        },
        {
          "id": "missing_delivery",
          "text": "Carriers sometimes mark 'delivered' early. Please: 1) Check with neighbors 2) Check mailroom/porch 3) Wait 24 hours. Found it?",
          "options": [
            {"text": "Found it, thanks!", "summary": "Package found", "next": "resolved_end"},
            {"text": "Still missing after 24h", "summary": "Really missing", "next": "contact"},
            {"text": "I want a refund now", "summary": "Impatient", "next": "contact"}
          ]
        },
        {
          "id": "carrier_delay",
          "text": "Carriers (USPS/FedEx/UPS) sometimes have delays. 95% arrive within 3 more days. Last tracking update?",
          "options": [
            {"text": "Within 3 days - I'll wait", "summary": "Customer waits", "next": "resolved_end"},
            {"text": "Over 5 days no update", "summary": "Stuck package", "next": "contact"}
          ]
        },
        {
          "id": "serious_delay",
          "text": "2+ weeks is not normal. Your package may be lost. Please provide your order number for investigation.",
          "options": [
            {"text": "DOR-_____ (I'll provide)", "summary": "Lost package", "next": "contact"},
            {"text": "I don't have order number", "summary": "Can't identify", "next": "contact"}
          ]
        },
        {
          "id": "damaged_package_check",
          "text": "Is the PRODUCT damaged or just the box?",
          "options": [
            {"text": "Just the box, product fine", "summary": "Box only", "next": "box_only_damage"},
            {"text": "Product is damaged/broken", "summary": "Product damaged", "next": "product_damaged_photo"},
            {"text": "Haven't opened yet", "summary": "Not opened", "next": "open_package_first"}
          ]
        },
        {
          "id": "box_only_damage",
          "text": "Great! If product works, no action needed. We over-pack for protection. Does product work?",
          "options": [
            {"text": "Yes, works perfectly", "summary": "No issue", "next": "resolved_end"},
            {"text": "No, it's broken too", "summary": "Hidden damage", "next": "product_damaged_photo"}
          ]
        },
        {
          "id": "open_package_first",
          "text": "Please open the package and check the actual product. Often the product is fine even if box is damaged.",
          "options": [
            {"text": "Product is perfect", "summary": "All good", "next": "resolved_end"},
            {"text": "Product is damaged", "summary": "Damaged", "next": "product_damaged_photo"}
          ]
        },
        {
          "id": "product_damaged_photo",
          "text": "We need photos of the damage for our shipping claim. Please email photos to claims@dornori.com with your order number. We'll send replacement within 48 hours.",
          "options": [
            {"text": "Will send photos, thanks", "summary": "Customer will email", "next": "resolved_end"},
            {"text": "No camera / can't take photos", "summary": "No photos", "next": "contact"},
            {"text": "Already sent photos", "summary": "Follow up needed", "next": "contact"}
          ]
        },
        {
          "id": "order_issue_check",
          "text": "What's wrong with your order?",
          "options": [
            {"text": "Wrong item sent", "summary": "Wrong product", "next": "wrong_product"},
            {"text": "Missing parts/accessories", "summary": "Missing items", "next": "missing_parts"},
            {"text": "Quantity wrong", "summary": "Quantity error", "next": "quantity_error"},
            {"text": "Wrong color/size", "summary": "Variant wrong", "next": "variant_error"}
          ]
        },
        {
          "id": "wrong_product",
          "text": "Warehouse mix-ups happen occasionally. We'll send the correct item. Please confirm your order number.",
          "options": [
            {"text": "Order number: DOR-_____", "summary": "Wrong item confirmed", "next": "contact"},
            {"text": "I'll check my order", "summary": "Customer checks", "next": "resolved_end"}
          ]
        },
        {
          "id": "missing_parts",
          "text": "Which parts are missing?",
          "options": [
            {"text": "USB cable / power adapter", "summary": "Missing cable", "next": "contact"},
            {"text": "Screws / hardware", "summary": "Missing hardware", "next": "contact"},
            {"text": "Instruction manual", "summary": "Missing manual", "next": "digital_manual"},
            {"text": "Major component", "summary": "Major part", "next": "contact"}
          ]
        },
        {
          "id": "digital_manual",
          "text": "Digital manuals available at https://dornori.com/manuals. Most issues are solved there. Does this help?",
          "options": [
            {"text": "Yes, found manual", "summary": "Manual found", "next": "resolved_end"},
            {"text": "No, need physical manual", "summary": "Physical needed", "next": "contact"}
          ]
        },
        {
          "id": "quantity_error",
          "text": "Did you order 1 and get 2, or order 2 and get 1?",
          "options": [
            {"text": "Ordered 2, got 1 (short)", "summary": "Short shipment", "next": "contact"},
            {"text": "Ordered 1, got 2 (extra)", "summary": "Extra item", "next": "keep_extra"}
          ]
        },
        {
          "id": "keep_extra",
          "text": "Please keep the extra as our gift! No need to return. Want 50% off another?",
          "options": [
            {"text": "Yes, discount please", "summary": "Discount wanted", "next": "contact"},
            {"text": "No, just being honest", "summary": "Honest customer", "next": "resolved_end"}
          ]
        },
        {
          "id": "variant_error",
          "text": "Wrong color/size? We can exchange. Please provide order number.",
          "options": [
            {"text": "DOR-_____ (providing)", "summary": "Exchange needed", "next": "contact"},
            {"text": "I'll live with it", "summary": "Accepting", "next": "resolved_end"}
          ]
        },
        {
          "id": "cancel_return",
          "text": "What would you like to do?",
          "options": [
            {"text": "Cancel order (not shipped)", "summary": "Cancel", "next": "cancel_order"},
            {"text": "Return item (already received)", "summary": "Return", "next": "return_item"},
            {"text": "Exchange for different item", "summary": "Exchange", "next": "exchange_item"}
          ]
        },
        {
          "id": "cancel_order",
          "text": "When did you order?",
          "options": [
            {"text": "Less than 1 hour ago", "summary": "Can cancel", "next": "cancel_easy"},
            {"text": "1-24 hours ago", "summary": "Maybe cancel", "next": "maybe_cancel"},
            {"text": "Over 24 hours", "summary": "Probably shipped", "next": "probably_shipped"}
          ]
        },
        {
          "id": "cancel_easy",
          "text": "Login to your account or reply to confirmation email with 'CANCEL'. Cancelled within 1 hour? No charge.",
          "options": [
            {"text": "Done, thanks", "summary": "Cancelled", "next": "resolved_end"},
            {"text": "Didn't work", "summary": "Failed", "next": "contact"}
          ]
        },
        {
          "id": "maybe_cancel",
          "text": "Your order may be packing. I'll need to check manually. Order number?",
          "options": [
            {"text": "DOR-_____ (providing)", "summary": "Manual check", "next": "contact"},
            {"text": "I'll try myself", "summary": "Self service", "next": "resolved_end"}
          ]
        },
        {
          "id": "probably_shipped",
          "text": "Order likely shipped. You can return for free within 30 days. Return label in your account.",
          "options": [
            {"text": "Will return, thanks", "summary": "Return", "next": "resolved_end"},
            {"text": "Need help returning", "summary": "Assisted", "next": "contact"}
          ]
        },
        {
          "id": "return_item",
          "text": "Free returns within 30 days. Items must be unused. Initiate return from your account dashboard.",
          "options": [
            {"text": "Return initiated", "summary": "Started", "next": "resolved_end"},
            {"text": "Dashboard not working", "summary": "Tech issue", "next": "contact"},
            {"text": "Item is used/defective", "summary": "Different", "next": "contact"}
          ]
        },
        {
          "id": "exchange_item",
          "text": "Exchange = return + new order. Return original (free label), place new order. Refund when received.",
          "options": [
            {"text": "Understood", "summary": "Clear", "next": "resolved_end"},
            {"text": "Too complicated", "summary": "Help needed", "next": "contact"}
          ]
        },
        {
          "id": "tracking_not_working",
          "text": "Tracking links sometimes take 24 hours to activate. What does it show?",
          "options": [
            {"text": "Label created, no movement", "summary": "Not shipped yet", "next": "not_shipped"},
            {"text": "Error / not found", "summary": "Wrong number", "next": "contact"},
            {"text": "Shows delivered but not here", "summary": "Missing", "next": "missing_delivery"}
          ]
        },
        {
          "id": "not_shipped",
          "text": "Label created means warehouse is packing. Ships within 48 hours. Check back then.",
          "options": [
            {"text": "Will wait, thanks", "summary": "Waiting", "next": "resolved_end"},
            {"text": "Been over 48 hours", "summary": "Delayed", "next": "contact"}
          ]
        }
      ]
    },
    {
      "id": "tracking_not_working",
      "title": "🔍 Tracking & Delivery Issues",
      "questions": [
        {
          "id": "tr1",
          "text": "What's wrong with your tracking?",
          "options": [
            {"text": "Tracking number not recognized", "summary": "Invalid tracking", "next": "invalid_tracking"},
            {"text": "No updates for days", "summary": "Stuck tracking", "next": "stuck_tracking"},
            {"text": "Shows delivered but no package", "summary": "False delivery", "next": "missing_delivery"},
            {"text": "Wrong address on tracking", "summary": "Address error", "next": "address_error"}
          ]
        },
        {
          "id": "invalid_tracking",
          "text": "Tracking numbers activate within 24 hours of shipping. When did you receive it?",
          "options": [
            {"text": "Less than 24 hours ago", "summary": "Too soon", "next": "wait_tracking"},
            {"text": "More than 24 hours", "summary": "Should work", "next": "contact"}
          ]
        },
        {
          "id": "wait_tracking",
          "text": "Please wait 24 hours. Most tracking activates by then. Still not working? Contact us.",
          "options": [
            {"text": "I'll wait", "summary": "Waiting", "next": "resolved_end"},
            {"text": "Still not working", "summary": "Still broken", "next": "contact"}
          ]
        },
        {
          "id": "stuck_tracking",
          "text": "How many days with no update?",
          "options": [
            {"text": "2-3 days", "summary": "Normal", "next": "normal_stuck"},
            {"text": "4-7 days", "summary": "Concerning", "next": "concerning_stuck"},
            {"text": "8+ days", "summary": "Lost", "next": "contact"}
          ]
        },
        {
          "id": "normal_stuck",
          "text": "Carriers sometimes skip scans. 95% update within 3 days. Check again tomorrow.",
          "options": [
            {"text": "Will do, thanks", "summary": "Patient", "next": "resolved_end"},
            {"text": "Still no update", "summary": "Escalate", "next": "contact"}
          ]
        },
        {
          "id": "concerning_stuck",
          "text": "4-7 days without update is unusual. Let me check your carrier. Carrier name?",
          "options": [
            {"text": "USPS", "summary": "USPS delay", "next": "usps_delay"},
            {"text": "FedEx", "summary": "FedEx delay", "next": "fedex_delay"},
            {"text": "UPS", "summary": "UPS delay", "next": "ups_delay"},
            {"text": "DHL", "summary": "DHL delay", "next": "dhl_delay"}
          ]
        },
        {
          "id": "usps_delay",
          "text": "USPS has known delays in some regions. 90% of stuck packages move within 5 more days. File a missing mail search?",
          "options": [
            {"text": "Yes, file search", "summary": "Mail search", "next": "contact"},
            {"text": "I'll wait longer", "summary": "Waiting", "next": "resolved_end"}
          ]
        },
        {
          "id": "fedex_delay",
          "text": "FedEx occasionally loses scans. Have you tried tracking on FedEx website directly?",
          "options": [
            {"text": "Same there - no update", "summary": "Still stuck", "next": "contact"},
            {"text": "It shows more info, thanks!", "summary": "Found info", "next": "resolved_end"}
          ]
        },
        {
          "id": "ups_delay",
          "text": "UPS SurePost sometimes has gaps. Last scan location? Check UPS site directly.",
          "options": [
            {"text": "Still stuck", "summary": "Still issue", "next": "contact"},
            {"text": "Found it", "summary": "Resolved", "next": "resolved_end"}
          ]
        },
        {
          "id": "dhl_delay",
          "text": "DHL eCommerce has limited tracking. Usually updates at delivery. Please allow 2 more days.",
          "options": [
            {"text": "Will wait", "summary": "Waiting", "next": "resolved_end"},
            {"text": "Need more help", "summary": "Escalate", "next": "contact"}
          ]
        },
        {
          "id": "address_error",
          "text": "Wrong address? If package hasn't shipped, we can fix it. Status?",
          "options": [
            {"text": "Not shipped yet", "summary": "Can fix", "next": "contact"},
            {"text": "Already shipped", "summary": "Can't fix", "next": "address_shipped"}
          ]
        },
        {
          "id": "address_shipped",
          "text": "Once shipped, we can't change address. You'll need to contact carrier or arrange pickup from wrong address.",
          "options": [
            {"text": "Understood", "summary": "Customer aware", "next": "resolved_end"},
            {"text": "Need help with carrier", "summary": "Assistance", "next": "contact"}
          ]
        }
      ]
    },
    {
      "id": "3d_printing",
      "title": "🖨️ 3D Printing & File Issues",
      "questions": [
        {
          "id": "3d1",
          "text": "Where is the failure happening?",
          "options": [
            {"text": "Won't slice / software error", "summary": "Slicer issue", "next": "slicer_issue"},
            {"text": "Print fails on my printer", "summary": "Printer issue", "next": "printer_issue"},
            {"text": "Poor print quality", "summary": "Quality issue", "next": "quality_issue"},
            {"text": "File won't download/open", "summary": "File issue", "next": "file_issue"}
          ]
        },
        {
          "id": "slicer_issue",
          "text": "Which slicer are you using?",
          "options": [
            {"text": "Bambu Studio", "summary": "Bambu slicer", "next": "bambu_slicer"},
            {"text": "PrusaSlicer", "summary": "Prusa slicer", "next": "prusa_slicer"},
            {"text": "Cura", "summary": "Cura slicer", "next": "cura_slicer"},
            {"text": "Orca Slicer", "summary": "Orca slicer", "next": "orca_slicer"},
            {"text": "Other", "summary": "Other slicer", "next": "other_slicer"}
          ]
        },
        {
          "id": "bambu_slicer",
          "text": "Common Bambu Studio issues: non-manifold geometry. Try 'Fix Model' in right-click menu. Worked?",
          "options": [
            {"text": "Yes, fixed!", "summary": "Fixed", "next": "resolved_end"},
            {"text": "No, still broken", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "prusa_slicer",
          "text": "PrusaSlicer has built-in repair. Right-click → 'Repair STL'. Also try increasing 'Detect thin walls'.",
          "options": [
            {"text": "Worked, thanks!", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Didn't work", "summary": "Still broken", "next": "contact"}
          ]
        },
        {
          "id": "cura_slicer",
          "text": "Cura fix: Enable 'Mesh Fixes' → 'Remove Holes' and 'Union Overlapping Volumes'. Try these?",
          "options": [
            {"text": "Fixed it!", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Still not working", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "orca_slicer",
          "text": "Orca has 'Repair STL' under Object menu. Also try loading in Bambu Studio first.",
          "options": [
            {"text": "Fixed, thanks", "summary": "Fixed", "next": "resolved_end"},
            {"text": "No luck", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "other_slicer",
          "text": "Try loading the STL in Tinkercad (free) or Microsoft 3D Builder to repair. Both have auto-repair.",
          "options": [
            {"text": "Will try, thanks", "summary": "Will attempt", "next": "resolved_end"},
            {"text": "Need native fixed file", "summary": "Request fixed", "next": "contact"}
          ]
        },
        {
          "id": "printer_issue",
          "text": "What printer brand?",
          "options": [
            {"text": "Bambu Lab", "summary": "Bambu printer", "next": "bambu_printer"},
            {"text": "Creality (Ender/CR)", "summary": "Creality", "next": "creality_printer"},
            {"text": "Prusa", "summary": "Prusa", "next": "prusa_printer"},
            {"text": "Anycubic", "summary": "Anycubic", "next": "anycubic_printer"},
            {"text": "Elegoo", "summary": "Elegoo", "next": "elegoo_printer"},
            {"text": "Other", "summary": "Other", "next": "other_printer"}
          ]
        },
        {
          "id": "bambu_printer",
          "text": "Bambu specific: Check AMS settings, filament type, and bed adhesion. Have you washed your build plate?",
          "options": [
            {"text": "Washing plate fixed it!", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Still having issues", "summary": "Still problem", "next": "contact"}
          ]
        },
        {
          "id": "creality_printer",
          "text": "Creality common fixes: level bed, adjust Z-offset, clean nozzle. Tried these?",
          "options": [
            {"text": "Leveling fixed it", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Still not working", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "prusa_printer",
          "text": "Prusa: Run self-test, recalibrate XYZ, check PINDA probe. Live Z adjust may help.",
          "options": [
            {"text": "Recalibration worked", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Still failing", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "anycubic_printer",
          "text": "Anycubic: Check resin settings (exposure time, lift speed). Increase bottom exposure by 20%.",
          "options": [
            {"text": "Adjusted, works now", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Still failing", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "elegoo_printer",
          "text": "Elegoo: Level bed, check FEP tension, increase exposure. Watch Elegoo YouTube tutorials.",
          "options": [
            {"text": "Tutorial helped", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Need more help", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "other_printer",
          "text": "Generic advice: Level bed, dry filament, check nozzle temp (PLA 200-210°, PETG 230-250°). Try these?",
          "options": [
            {"text": "Temperature adjustment helped", "summary": "Fixed", "next": "resolved_end"},
            {"text": "No improvement", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "quality_issue",
          "text": "What quality problem?",
          "options": [
            {"text": "Stringing / oozing", "summary": "Stringing", "next": "stringing_fix"},
            {"text": "Layer lines visible / rough", "summary": "Layer lines", "next": "layer_lines_fix"},
            {"text": "Warping / corners lifting", "summary": "Warping", "next": "warping_fix"},
            {"text": "Gaps or under-extrusion", "summary": "Under-extrusion", "next": "underextrusion_fix"},
            {"text": "Blobs / zits on surface", "summary": "Blobs", "next": "blobs_fix"}
          ]
        },
        {
          "id": "stringing_fix",
          "text": "Stringing usually = retraction or temperature. Increase retraction to 5mm @ 40mm/s. Also dry your filament.",
          "options": [
            {"text": "Retraction adjustment fixed it", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Still stringing", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "layer_lines_fix",
          "text": "Visible layer lines = layer height too large? Try 0.12mm instead of 0.2mm. Also check belt tension.",
          "options": [
            {"text": "Smaller layer height helped", "summary": "Fixed", "next": "resolved_end"},
            {"text": "No improvement", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "warping_fix",
          "text": "Warping fix: Use brim, increase bed temp (PLA 60°, ABS 100°), eliminate drafts, use enclosure.",
          "options": [
            {"text": "Brim + higher bed temp worked", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Still warping", "summary": "Still issue", "next": "contact"}
          ]
        },
        {
          "id": "underextrusion_fix",
          "text": "Under-extrusion: Clean nozzle, check extruder tension, calibrate e-steps, increase flow to 105%.",
          "options": [
            {"text": "Cleaning nozzle fixed it", "summary": "Fixed", "next": "resolved_end"},
            {"text": "Still under-extruding", "summary": "Still issue", "next": "contact"}
          ]
        },
