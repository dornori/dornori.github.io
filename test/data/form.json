            {"text": "Wrong item sent", "summary": "Wrong product", "next": "wrong_product", "resolves": false},
            {"text": "Missing parts/accessories", "summary": "Missing items", "next": "missing_parts", "resolves": false},
            {"text": "Quantity wrong", "summary": "Quantity error", "next": "quantity_error", "resolves": false},
            {"text": "Actually it's correct, my mistake", "summary": "User error", "next": "resolved_end", "resolves": true}
          ]
        },
