          "id": "wrong_product",
          "text": "We'll send the correct item. Please confirm your order number.",
          "options": [
            {"text": "Order number: DOR-_____", "summary": "Wrong item confirmed", "next": "contact", "resolves": false},
            {"text": "I'll keep it instead", "summary": "Customer keeps", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "missing_parts",
          "text": "Which parts are missing?",
          "options": [
            {"text": "USB cable / power adapter", "summary": "Missing cable", "next": "contact", "resolves": false},
            {"text": "Screws / hardware", "summary": "Missing hardware", "next": "contact", "resolves": false},
            {"text": "Found them in the box!", "summary": "Found parts", "next": "resolved_end", "resolves": true},
            {"text": "I'll use my own", "summary": "Customer has parts", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "quantity_error",
          "text": "Did you order 1 and get 2, or order 2 and get 1?",
          "options": [
            {"text": "Ordered 2, got 1 (short)", "summary": "Short shipment", "next": "contact", "resolves": false},
            {"text": "Ordered 1, got 2 (extra)", "summary": "Extra item", "next": "keep_extra", "resolves": false}
          ]
        },
        {
          "id": "keep_extra",
          "text": "Please keep the extra as our gift! Want 50% off another?",
          "options": [
            {"text": "Yes, discount please", "summary": "Discount wanted", "next": "contact", "resolves": false},
            {"text": "No, thanks for the gift!", "summary": "Happy customer", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "cancel_return",
          "text": "What would you like to do?",
          "options": [
            {"text": "Cancel order (not shipped)", "summary": "Cancel", "next": "cancel_order", "resolves": false},
            {"text": "Return item (already received)", "summary": "Return", "next": "return_item", "resolves": false},
            {"text": "Never mind, I'll keep it", "summary": "Keep item", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "cancel_order",
          "text": "When did you order?",
          "options": [
            {"text": "Less than 1 hour ago", "summary": "Can cancel", "next": "cancel_easy", "resolves": false},
            {"text": "1-24 hours ago", "summary": "Maybe cancel", "next": "maybe_cancel", "resolves": false},
            {"text": "Over 24 hours - I'll keep it", "summary": "Keep", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "cancel_easy",
          "text": "Login to your account or reply to confirmation email with 'CANCEL'.",
          "options": [
            {"text": "Done, thanks", "summary": "Cancelled", "next": "resolved_end", "resolves": true},
            {"text": "Didn't work", "summary": "Failed", "next": "contact", "resolves": false}
          ]
        },
        {
          "id": "maybe_cancel",
          "text": "Your order may be packing. I'll need to check manually. Order number?",
          "options": [
            {"text": "DOR-_____ (providing)", "summary": "Manual check", "next": "contact", "resolves": false},
            {"text": "I'll try myself first", "summary": "Self service", "next": "resolved_end", "resolves": true}
          ]
        },
        {
          "id": "return_item",
          "text": "Free returns within 30 days. Initiate return from your account dashboard.",
          "options": [
            {"text": "Return initiated, thanks", "summary": "Started", "next": "resolved_end", "resolves": true},
            {"text": "Dashboard not working", "summary": "Tech issue", "next": "contact", "resolves": false}
          ]
        },
        {
          "id": "tracking_not_working",
          "text": "Tracking links sometimes take 24 hours to activate.",
          "options": [
            {"text": "I'll wait, thanks", "summary": "Waiting", "next": "resolved_end", "resolves": true},
            {"text": "Still not working after 24h", "summary": "Still broken", "next": "contact", "resolves": false}
          ]
        }
      ]
    },
