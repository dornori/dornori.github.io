          "id": "product_damaged_photo",
          "text": "Please email photos of damage to claims@dornori.com with your order number.",
          "options": [
            {"text": "Will send photos, thanks", "summary": "Customer will email", "next": "resolved_end", "resolves": true},
            {"text": "Need a return label", "summary": "Return needed", "next": "contact", "resolves": false}
          ]
