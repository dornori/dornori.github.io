{
  "title": "Dornori Enterprise Support Center",
  "subtitle": "Advanced diagnostics for 3D printing, electronics, and assembly",
  "categories": [
    {
      "id": "3dfiles",
      "title": "📁 3D Files & Slicing Issues",
      "questions": [
        {
          "id": "f1",
          "text": "Where exactly is the failure occurring?",
          "options": [
            {"text": "Fails when opening/slicing in software", "summary": "Software/slicer issue", "next": "slicer_issues"},
            {"text": "Fails during printing on my printer", "summary": "Printer/hardware issue", "next": "printer_issues"},
            {"text": "Fails after printing (quality problems)", "summary": "Print quality issue", "next": "quality_issues"},
            {"text": "Files won't download or are corrupted", "summary": "File download/corruption issue", "next": "contact"}
          ]
        },
        {
          "id": "slicer_issues",
          "text": "Which slicer software are you using?",
          "options": [
            {"text": "Bambu Studio", "summary": "Bambu Studio slicer issue", "next": "bambu_slicer"},
            {"text": "Orca Slicer", "summary": "Orca Slicer issue", "next": "orca_slicer"},
            {"text": "PrusaSlicer", "summary": "PrusaSlicer issue", "next": "prusa_slicer"},
            {"text": "Cura (UltiMaker Cura)", "summary": "Cura slicer issue", "next": "cura_slicer"},
            {"text": "Simplify3D", "summary": "Simplify3D issue", "next": "s3d_slicer"},
            {"text": "Lychee Slicer (Resin)", "summary": "Lychee Slicer issue", "next": "lychee_slicer"},
            {"text": "Chitubox (Resin)", "summary": "Chitubox issue", "next": "chitubox_slicer"},
            {"text": "Creality Print", "summary": "Creality slicer issue", "next": "creality_slicer"},
            {"text": "Anycubic Photon Workshop", "summary": "Anycubic slicer issue", "next": "anycubic_slicer"},
            {"text": "Other slicer", "summary": "Other slicer software", "next": "other_slicer"}
          ]
        },
        {
          "id": "bambu_slicer",
          "text": "What happens when you try to load the STL/3MF file in Bambu Studio?",
          "options": [
            {"text": "File won't load at all - error message", "summary": "Bambu Studio - file load error", "next": "file_error"},
            {"text": "File loads but shows errors (red exclamation)", "summary": "Bambu Studio - mesh errors detected", "next": "mesh_error"},
            {"text": "Slicing fails or gets stuck at X%", "summary": "Bambu Studio - slicing freeze", "next": "slicing_freeze"},
            {"text": "Preview shows missing layers or gaps", "summary": "Bambu Studio - slicing artifact", "next": "slicing_artifact"},
            {"text": "File works perfectly", "summary": "", "next": "contact"}
          ]
        },
        {
          "id": "prusa_slicer",
          "text": "What happens when you try to load the file in PrusaSlicer?",
          "options": [
            {"text": "File won't import - format not recognized", "summary": "PrusaSlicer - import failure", "next": "file_error"},
            {"text": "Object is completely red (manifold error)", "summary": "PrusaSlicer - non-manifold geometry", "next": "mesh_error"},
            {"text": "Slicer crashes when repairing", "summary": "PrusaSlicer - crash during repair", "next": "slicer_crash"},
            {"text": "Slices but has strange artifacts", "summary": "PrusaSlicer - slicing artifact", "next": "slicing_artifact"},
            {"text": "File works fine", "summary": "", "next": "contact"}
          ]
        },
        {
          "id": "cura_slicer",
          "text": "What issue are you experiencing in Cura?",
          "options": [
            {"text": "File loads but shows as empty/invisible", "summary": "Cura - model invisible or scale 0", "next": "file_error"},
            {"text": "Cura shows error 'Model not watertight'", "summary": "Cura - watertightness error", "next": "mesh_error"},
            {"text": "Cura freezes when applying supports", "summary": "Cura - support generation crash", "next": "slicer_crash"},
            {"text": "Estimated print time is wrong/hours off", "summary": "Cura - time estimation bug", "next": "contact"},
            {"text": "Works correctly", "summary": "", "next": "contact"}
          ]
        },
        {
          "id": "mesh_error",
          "text": "What type of mesh error is reported?",
          "options": [
            {"text": "Non-manifold edges (holes in mesh)", "summary": "Mesh has holes or open edges - needs repair", "next": "contact"},
            {"text": "Inverted normals (faces pointing wrong way)", "summary": "Normal orientation flipped - flip normals", "next": "contact"},
            {"text": "Self-intersecting geometry", "summary": "Mesh intersects itself - Boolean repair needed", "next": "contact"},
            {"text": "Too many triangles (high poly count)", "summary": "Mesh too complex - decimation needed", "next": "contact"},
            {"text": "Unknown error - no specific message", "summary": "Generic mesh corruption", "next": "contact"}
          ]
        },
        {
          "id": "printer_issues",
          "text": "What brand of 3D printer are you using?",
          "options": [
            {"text": "Bambu Lab (X1, P1, A1 series)", "summary": "Bambu Lab printer", "next": "bambu_printer"},
            {"text": "Creality (Ender, CR, K1 series)", "summary": "Creality printer", "next": "creality_printer"},
            {"text": "Prusa (MK, XL, Mini series)", "summary": "Prusa printer", "next": "prusa_printer"},
            {"text": "Anycubic (Kobra, Vyper, Photon)", "summary": "Anycubic printer", "next": "anycubic_printer"},
            {"text": "Elegoo (Neptune, Mars, Saturn)", "summary": "Elegoo printer", "next": "elegoo_printer"},
            {"text": "FlashForge (Adventurer, Creator)", "summary": "FlashForge printer", "next": "flashforge_printer"},
            {"text": "QIDI Tech (X series, iFast)", "summary": "QIDI printer", "next": "qidi_printer"},
            {"text": "Sovol (SV04, SV06, SV07)", "summary": "Sovol printer", "next": "sovol_printer"},
            {"text": "Voron (custom CoreXY)", "summary": "Voron printer", "next": "voron_printer"},
            {"text": "Rat Rig (V-Core)", "summary": "Rat Rig printer", "next": "ratrig_printer"},
            {"text": "AnkerMake (M5)", "summary": "AnkerMake printer", "next": "ankermake_printer"},
            {"text": "Artillery (Sidewinder, Genius, Hornet)", "summary": "Artillery printer", "next": "artillery_printer"},
            {"text": "Monoprice (MP Select, Mini Delta)", "summary": "Monoprice printer", "next": "monoprice_printer"},
            {"text": "LulzBot (TAZ, Mini, Workhorse)", "summary": "LulzBot printer", "next": "lulzbot_printer"},
            {"text": "Raise3D (Pro series, E2)", "summary": "Raise3D printer", "next": "raise3d_printer"},
            {"text": "UltiMaker (S series, 2+ series)", "summary": "UltiMaker printer", "next": "ultimaker_printer"},
            {"text": "Snapmaker (Artisan, J1, A350)", "summary": "Snapmaker printer", "next": "snapmaker_printer"},
            {"text": "Other / Custom build", "summary": "Other printer brand", "next": "other_printer"}
          ]
        },
        {
          "id": "bambu_printer",
          "text": "What specific issue occurs when printing Dornori files?",
          "options": [
            {"text": "AMS won't load or recognize filament", "summary": "Bambu AMS issue", "next": "bambu_ams"},
            {"text": "First layer fails / doesn't stick", "summary": "Bambu first layer adhesion", "next": "first_layer"},
            {"text": "Print fails mid-print (spaghetti)", "summary": "Bambu mid-print failure", "next": "mid_print_fail"},
            {"text": "Lidar/AI detection causes false stops", "summary": "Bambu AI detection issue", "next": "contact"},
            {"text": "File won't send via cloud/network", "summary": "Bambu cloud send error", "next": "contact"}
          ]
        },
        {
          "id": "creality_printer",
          "text": "What specific Creality printer issue?",
          "options": [
            {"text": "Print doesn't start - thermal runaway", "summary": "Creality thermal error", "next": "contact"},
            {"text": "Z-offset issues / bed leveling fails", "summary": "Creality bed level problem", "next": "first_layer"},
            {"text": "Filament jam in extruder", "summary": "Creality extruder jam", "next": "contact"},
            {"text": "Klipper firmware errors (Sonic Pad)", "summary": "Creality Klipper issue", "next": "contact"},
            {"text": "Works fine after adjustments", "summary": "", "next": "contact"}
          ]
        },
        {
          "id": "first_layer",
          "text": "Describe the first layer problem in detail",
          "options": [
            {"text": "Filament won't stick to build plate at all", "summary": "Adhesion failure - clean/level bed", "next": "contact"},
            {"text": "First layer has gaps between lines", "summary": "Under-extrusion on first layer", "next": "contact"},
            {"text": "Nozzle scratches/drags through print", "summary": "Z-offset too low - nozzle too close", "next": "contact"},
            {"text": "Filament curls up around nozzle", "summary": "Nozzle too far - poor squish", "next": "contact"}
          ]
        },
        {
          "id": "mid_print_fail",
          "text": "Where does the failure happen during printing?",
          "options": [
            {"text": "Within first 10 layers", "summary": "Early layer failure - adhesion or cooling", "next": "contact"},
            {"text": "At overhang or bridge section", "summary": "Overhang failure - need supports or cooling", "next": "contact"},
            {"text": "At layer change / Z-seam area", "summary": "Z-seam or layer shift issue", "next": "contact"},
            {"text": "Randomly - different each time", "summary": "Intermittent failure - check filament/voltage", "next": "contact"}
          ]
        },
        {
          "id": "quality_issues",
          "text": "What specific print quality problem are you seeing?",
          "options": [
            {"text": "Stringing / oozing between parts", "summary": "Retraction or temperature too high", "next": "stringing_fix"},
            {"text": "Layer lines very visible / rough surface", "summary": "Poor cooling or layer height too large", "next": "layer_lines"},
            {"text": "Warping - corners lifting off bed", "summary": "Bed temp, drafts, or enclosure needed", "next": "warping_fix"},
            {"text": "Z-banding / ribbed surface", "summary": "Z-axis binding or leadscrew issue", "next": "z_banding"},
            {"text": "Ghosting / ringing / echoes", "summary": "Acceleration/jerk too high or loose belts", "next": "ringing_fix"},
            {"text": "Gaps between walls / infill showing", "summary": "Under-extrusion or low infill overlap", "next": "gaps_fix"},
            {"text": "Blobs / zits on outer surface", "summary": "Moisture in filament or retraction issue", "next": "blobs_fix"},
            {"text": "Elephant foot (bulging at bottom)", "summary": "First layer squish too much", "next": "elephant_foot"}
          ]
        },
        {
          "id": "stringing_fix",
          "text": "What filament type and temperature are you using?",
          "options": [
            {"text": "PLA at 190-200°C - still stringing", "summary": "PLA - increase retraction (5mm/40mm/s)", "next": "contact"},
            {"text": "PLA at 210-220°C - stringing", "summary": "PLA too hot - lower to 195°C", "next": "contact"},
            {"text": "PETG - severe stringing", "summary": "PETG - dry filament, reduce temp, increase retraction", "next": "contact"},
            {"text": "TPU - flexible stringing", "summary": "TPU - slow speed, direct drive required", "next": "contact"},
            {"text": "ABS/ASA - stringing and warping", "summary": "ABS - enclosure needed, dry filament", "next": "contact"}
          ]
        },
        {
          "id": "other_printer",
          "text": "Please specify your printer brand and model",
          "options": [
            {"text": "I'll provide details in the form", "summary": "Custom printer information needed", "next": "contact"}
          ]
        },
        {
          "id": "file_error",
          "text": "Would you like us to repair the file or provide a different format?",
          "options": [
            {"text": "Yes - please repair the STL file", "summary": "File repair request", "next": "contact"},
            {"text": "Yes - send me STEP/IGES instead", "summary": "CAD format request", "next": "contact"},
            {"text": "Maybe - need to try other options first", "summary": "Further troubleshooting needed", "next": "contact"}
          ]
        },
        {
          "id": "slicer_crash",
          "text": "Does the crash happen with a specific Dornori file or any STL?",
          "options": [
            {"text": "Only Dornori files - others work fine", "summary": "Dornori-specific file issue", "next": "contact"},
            {"text": "Happens with all STL files", "summary": "Slicer/PC issue - reinstall slicer", "next": "contact"},
            {"text": "Random - sometimes works, sometimes crashes", "summary": "Memory/system issue - try smaller file", "next": "contact"}
          ]
        },
        {
          "id": "slicing_artifact",
          "text": "What does the artifact look like in preview?",
          "options": [
            {"text": "Missing layers in specific Z height", "summary": "Slicer bug or model error", "next": "contact"},
            {"text": "Holes or missing geometry", "summary": "Non-manifold mesh at that location", "next": "mesh_error"},
            {"text": "Extra spikes or towers", "summary": "Inverted normals or corrupted vertices", "next": "contact"},
            {"text": "Scale is wrong - part too small/large", "summary": "Unit mismatch - scale 1000% or 10%", "next": "contact"}
          ]
        }
      ]
    },
    {
      "id": "assembly",
      "title": "🛠️ Kit Assembly & Fitment Issues",
      "questions": [
        {
          "id": "a1",
          "text": "What type of assembly problem are you experiencing?",
          "options": [
            {"text": "Parts won't snap together", "summary": "Fitment/tolerance issue", "next": "fitment_details"},
            {"text": "Parts are too loose / wobble", "summary": "Loose fitment issue", "next": "loose_fit"},
            {"text": "Missing or broken parts", "summary": "Missing/damaged parts", "next": "missing_parts"},
            {"text": "Screws/hardware issues", "summary": "Hardware problem", "next": "hardware_issues"},
            {"text": "Instructions unclear", "summary": "Manual/guide issue", "next": "instruction_issue"}
          ]
        },
        {
          "id": "fitment_details",
          "text": "Which specific connection is giving you trouble?",
          "options": [
            {"text": "Base to main column connection", "summary": "Base fitment too tight", "next": "contact"},
            {"text": "Lamp head to arm joint", "summary": "Head joint too tight/loose", "next": "contact"},
            {"text": "Plastic clip/snap connections", "summary": "Snap-fit too tight - sand lightly", "next": "contact"},
            {"text": "All connections are extremely tight", "summary": "General tolerance issue - batch problem", "next": "contact"}
          ]
        },
        {
          "id": "loose_fit",
          "text": "When does the wobble or looseness occur?",
          "options": [
            {"text": "Immediately after assembly", "summary": "Loose from start - tolerance issue", "next": "contact"},
            {"text": "After moving or adjusting position", "summary": "Joint wears over time - design issue", "next": "contact"},
            {"text": "Only when lamp is fully extended", "summary": "Weight/leverage issue - needs reinforcement", "next": "contact"}
          ]
        },
        {
          "id": "missing_parts",
          "text": "What parts are missing from your kit?",
          "options": [
            {"text": "Plastic structural pieces", "summary": "Missing plastic components", "next": "contact"},
            {"text": "Screws, nuts, or washers", "summary": "Missing hardware kit", "next": "contact"},
            {"text": "LED module or wiring", "summary": "Missing electrical components", "next": "contact"},
            {"text": "Diffuser or lampshade", "summary": "Missing optical component", "next": "contact"},
            {"text": "USB cable or power adapter", "summary": "Missing accessory", "next": "contact"}
          ]
        },
        {
          "id": "hardware_issues",
          "text": "What hardware problem are you seeing?",
          "options": [
            {"text": "Screws strip when tightening", "summary": "Soft screws or overtightened", "next": "contact"},
            {"text": "Screw holes don't align with inserts", "summary": "Mold alignment issue", "next": "contact"},
            {"text": "Nuts won't stay in hex pockets", "summary": "Hex pocket too large - glue needed", "next": "contact"},
            {"text": "Threaded inserts pulled out", "summary": "Insert failed - replace part", "next": "contact"}
          ]
        },
        {
          "id": "instruction_issue",
          "text": "What would help clarify the instructions?",
          "options": [
            {"text": "Video tutorial would be better", "summary": "Video guide request", "next": "contact"},
            {"text": "3D interactive model needed", "summary": "3D assembly viewer request", "next": "contact"},
            {"text": "Step numbers don't match parts", "summary": "Documentation error - mismatch", "next": "contact"},
            {"text": "Images are too small/low resolution", "summary": "Higher quality images needed", "next": "contact"}
          ]
        }
      ]
    },
    {
      "id": "electronics",
      "title": "💡 Electronics & LED Issues",
      "questions": [
        {
          "id": "e1",
          "text": "What type of electrical issue are you experiencing?",
          "options": [
            {"text": "Lamp won't turn on at all", "summary": "Complete power failure", "next": "power_failure"},
            {"text": "Lamp turns on but flickers", "summary": "Flickering issue", "next": "flickering_issue"},
            {"text": "Brightness problem (too dim/bright)", "summary": "Brightness issue", "next": "brightness_issue"},
            {"text": "Color temperature problem", "summary": "Color temp issue", "next": "color_issue"},
            {"text": "Buzzing noise", "summary": "Electrical noise issue", "next": "buzzing_noise"}
          ]
        },
        {
          "id": "power_failure",
          "text": "Have you tried the following troubleshooting steps?",
          "options": [
            {"text": "Yes - different USB cable and power adapter", "summary": "Cable/adapter not the issue", "next": "contact"},
            {"text": "Yes - different power outlet", "summary": "Outlet not the issue", "next": "contact"},
            {"text": "Yes - checked for loose wires inside", "summary": "Internal connection possible", "next": "contact"},
            {"text": "No - I'll try these first", "summary": "Will test before contacting", "next": "contact"}
          ]
        },
        {
          "id": "flickering_issue",
          "text": "When does the flickering occur?",
          "options": [
            {"text": "Constantly - always flickering", "summary": "Driver or LED failure", "next": "contact"},
            {"text": "Only when dimmed below 50%", "summary": "PWM flicker - driver issue", "next": "contact"},
            {"text": "When I touch or move the lamp", "summary": "Loose connection - inspect wiring", "next": "contact"},
            {"text": "After running for 30+ minutes", "summary": "Overheating - thermal shutdown", "next": "contact"}
          ]
        },
        {
          "id": "brightness_issue",
          "text": "What is the brightness compared to expectation?",
          "options": [
            {"text": "Much dimmer than advertised", "summary": "Underpowered driver or defective LEDs", "next": "contact"},
            {"text": "Too bright - blinding / uncomfortable", "summary": "Overpowered or wrong LED bin", "next": "contact"},
            {"text": "Brightness uneven across lamp", "summary": "Uneven LED distribution", "next": "contact"},
            {"text": "Brightness fluctuates on its own", "summary": "Driver instability", "next": "contact"}
          ]
        },
        {
          "id": "color_issue",
          "text": "What color temperature problem?",
          "options": [
            {"text": "Too yellow/warm (looks like 2700K)", "summary": "Wrong LED - warm white only", "next": "contact"},
            {"text": "Too blue/cool (looks like 6500K)", "summary": "Wrong LED - cool white only", "next": "contact"},
            {"text": "Color changes to green/pink tint", "summary": "LED degradation or phosphor issue", "next": "contact"},
            {"text": "Color not matching other Dornori lamps", "summary": "Batch variation - unmatched units", "next": "contact"}
          ]
        },
        {
          "id": "buzzing_noise",
          "text": "Where does the buzzing sound come from?",
          "options": [
            {"text": "From the power adapter/brick", "summary": "Adapter coil whine - normal", "next": "contact"},
            {"text": "From the lamp head/LED driver", "summary": "Driver coil whine - component issue", "next": "contact"},
            {"text": "Only when dimmed to certain level", "summary": "PWM frequency audible - design issue", "next": "contact"},
            {"text": "Constant loud buzzing", "summary": "Failing component - replace driver", "next": "contact"}
          ]
        }
      ]
    }
  ]
}
